# ─────────────────────────────────────────────────────────────────
# OpenWISP connection
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Authentication – use either a static token OR username/password.
# A static token takes priority over username/password.
OPENWISP_AUTH_URL=https://openwisp.example.com/api/v1/users/token/
OPENWISP_TOKEN=                          # optional static Bearer token
OPENWISP_BASE_URL=https://openwisp.example.com
OPENWISP_USERNAME=your_username
OPENWISP_PASSWORD=your_password

# Set to true only if your server has a valid certificate chain.
OPENWISP_VERIFY_SSL=false

# ─────────────────────────────────────────────────────────────────
# Application tuning
# ─────────────────────────────────────────────────────────────────

OPENWISP_DB_PATH=rssi_lb.sqlite3         # path to the SQLite database
OPENWISP_POLL_INTERVAL=5.0               # seconds between monitoring polls
OPENWISP_CLIENT_DIFF_THRESHOLD=2         # minimum client imbalance to trigger an action
OPENWISP_TXPOWER_STEP=3                  # kept for future tx-power policy (unused by default)
OPENWISP_MIN_TXPOWER=8
OPENWISP_MAX_TXPOWER=23
OPENWISP_CONTROL_COOLDOWN=30             # seconds to wait between two consecutive actions
OPENWISP_TARGET_SSID=YourSSID            # SSID used to filter relevant radio interfaces

# ─────────────────────────────────────────────────────────────────
# Access Point 1
# ─────────────────────────────────────────────────────────────────

AP1_NAME=AP1
AP1_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx   # UUID from OpenWISP
AP1_DEVICE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx       # monitoring key
AP1_CONTROL_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # UUID for command POST (can equal AP1_DEVICE_ID)

# Configure at least one radio band (2G, 5G, or 6G).
AP1_RADIO_2G_IFACE=phy0.0-ap0
AP1_RADIO_2G_UCI=radio0
AP1_RADIO_5G_IFACE=phy0.1-ap0
AP1_RADIO_5G_UCI=radio1
AP1_RADIO_6G_IFACE=phy0.2-ap0
AP1_RADIO_6G_UCI=radio2

# ─────────────────────────────────────────────────────────────────
# Access Point 2
# ─────────────────────────────────────────────────────────────────

AP2_NAME=AP2
AP2_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AP2_DEVICE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AP2_CONTROL_DEVICE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

AP2_RADIO_2G_IFACE=phy0.0-ap0
AP2_RADIO_2G_UCI=radio0
AP2_RADIO_5G_IFACE=phy0.1-ap0
AP2_RADIO_5G_UCI=radio1
AP2_RADIO_6G_IFACE=phy0.2-ap0
AP2_RADIO_6G_UCI=radio2
